---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}
			.section-title {
				font-size: 0.9rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.4em;
				margin: 1.5em 0 1em 0;
			}
			.featured {
				display: grid;
				grid-template-columns: 1.2fr 1fr;
				gap: 2em;
				align-items: center;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 2em;
			}
			.featured img {
				width: 100%;
				border-radius: 12px;
				display: block;
			}
			.featured .title {
				margin: 0 0 0.4em 0;
				font-size: 1.9rem;
				line-height: 1.2;
				color: rgb(var(--black));
			}
			.featured .description {
				color: rgb(var(--gray-dark));
				line-height: 1.6;
			}
			.date {
				margin: 0.3em 0 0.6em 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			a.card-link {
				text-decoration: none;
				display: block;
			}
			.news-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
			}
			.news-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 1em;
			}
			.news-list img {
				width: 100%;
				border-radius: 10px;
				margin-bottom: 0.6em;
				display: block;
			}
			.news-list .title {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.35;
				color: rgb(var(--black));
			}
			a:hover .title,
			a:hover .date {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.featured {
					grid-template-columns: 1fr;
				}
				.news-list {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h2 class="section-title">今日焦點</h2>
			{
				featured && (
					<a class="card-link" href={`/blog/${featured.id}/`}>
						<div class="featured">
							<img width={720} height={360} src={featured.data.heroImage} alt="" />
							<div>
								<p class="date">
									<FormattedDate date={featured.data.pubDate} />
								</p>
								<h1 class="title">{featured.data.title}</h1>
								<p class="description">{featured.data.description}</p>
							</div>
						</div>
					</a>
				)
			}

			<h2 class="section-title">更多新聞</h2>
			<ul class="news-list">
				{
					rest.map((post) => (
						<li>
							<a class="card-link" href={`/blog/${post.id}/`}>
								<img width={360} height={200} src={post.data.heroImage} alt="" />
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h4 class="title">{post.data.title}</h4>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
