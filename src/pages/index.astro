---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, getCategoryName } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredSlides = posts.slice(0, 5);
const rest = posts.slice(1);

const popularCandidates = posts.slice(0, 12).map((post) => ({
	id: post.id,
	title: post.data.title,
	heroImage: post.data.heroImage ?? '',
	category: post.data.category ?? '',
	categoryName: post.data.category ? getCategoryName(post.data.category) : '',
	pubDate: post.data.pubDate.getTime(),
}));
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				overflow-x: hidden;
			}
			.site-tagline {
				font-size: 0.95rem;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				margin: 1em 0 0 0;
			}
			.section-title {
				font-size: 0.9rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.4em;
				margin: 0 0 0.3em 0;
			}
			.section-sub {
				margin: 0.6em 0 1.3em 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.featured-section {
				margin-top: 1.5em;
			}
			.carousel-outer {
				position: relative;
				background: #a0c8fa;
				border-radius: 20px;
				padding: 28px 56px;
				box-sizing: border-box;
			}
			@media (max-width: 720px) {
				.carousel-outer {
					padding: 16px 40px;
				}
			}
			.carousel {
				display: grid;
			}
			.carousel a.slide {
				grid-area: 1 / 1;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 24px;
				align-items: stretch;
				visibility: hidden;
				opacity: 0;
				pointer-events: none;
			}
			@media (prefers-reduced-motion: no-preference) {
				.carousel a.slide {
					transition: opacity 0.25s ease;
				}
			}
			.carousel a.slide.is-active {
				visibility: visible;
				opacity: 1;
				pointer-events: auto;
			}
			.slide-text {
				background: #fff;
				border-radius: 14px;
				padding: 28px;
				display: flex;
				flex-direction: column;
				justify-content: center;
				box-sizing: border-box;
			}
			.slide img {
				width: 100%;
				height: 100%;
				min-height: 320px;
				object-fit: contain;
				object-position: center;
				border-radius: 14px;
				display: block;
				background: rgba(255, 255, 255, 0.15);
			}
			.slide .title {
				margin: 0 0 0.5em 0;
				font-size: 1.7rem;
				line-height: 1.4;
				color: rgb(var(--black));
			}
			.slide .description {
				color: rgb(var(--gray-dark));
				line-height: 1.7;
				margin: 0;
			}
			.date {
				margin: 0.3em 0 0.6em 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.category-badge {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.75rem;
				font-weight: 700;
				padding: 0.2em 0.7em;
				border-radius: 4px;
				margin-bottom: 0.5em;
				width: fit-content;
			}
			.carousel-arrow {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				z-index: 5;
				width: 40px;
				height: 40px;
				border-radius: 50%;
				border: none;
				background: #fff;
				color: rgb(var(--gray-dark));
				font-size: 1.4rem;
				line-height: 1;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				box-shadow: var(--box-shadow);
			}
			.carousel-arrow:hover {
				color: var(--accent);
			}
			.carousel-arrow.prev {
				left: 12px;
			}
			.carousel-arrow.next {
				right: 12px;
			}
			.carousel-dots {
				display: flex;
				justify-content: center;
				gap: 0.5em;
				margin-top: 1.2em;
			}
			.carousel-dots button {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				border: none;
				background: rgba(255, 255, 255, 0.5);
				padding: 0;
				cursor: pointer;
			}
			.carousel-dots button.is-active {
				background: #fff;
				width: 22px;
				border-radius: 4px;
				transition: width 0.2s ease;
			}
			a.card-link {
				text-decoration: none;
				display: block;
			}

			/* ===== Two-column section (spec-driven) ===== */
			.two-col-section {
				max-width: 1180px;
				margin: 56px auto 0 auto;
				display: grid;
				grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
				column-gap: 40px;
				align-items: start;
			}
			@media (max-width: 720px) {
				.two-col-section {
					grid-template-columns: 1fr;
					row-gap: 44px;
					margin-top: 40px;
				}
			}
			.col-heading {
				font-size: 20px;
				font-weight: 600;
				color: #171717;
				margin: 0 0 4px 0;
				padding-bottom: 10px;
				border-bottom: 1px solid #d8d8d8;
				position: relative;
			}
			.col-heading::after {
				content: '';
				position: absolute;
				left: 0;
				bottom: -1px;
				width: 48px;
				height: 2px;
				background: var(--accent);
			}

			/* ----- Latest articles list ----- */
			.latest-list {
				list-style: none;
				margin: 20px 0 0 0;
				padding: 0;
			}
			.latest-list li {
				display: grid;
				grid-template-columns: 220px minmax(0, 1fr);
				column-gap: 16px;
				align-items: start;
				padding: 14px 0 20px;
				border-bottom: 1px solid #e2e2e2;
			}
			.latest-list li:first-child {
				padding-top: 0;
			}
			.latest-list a {
				display: contents;
				text-decoration: none;
			}
			.latest-list img {
				width: 220px;
				height: 128px;
				object-fit: cover;
				border-radius: 4px;
				display: block;
			}
			.latest-list .l-category {
				font-size: 14px;
				color: var(--accent);
				font-weight: 600;
				margin: 0 0 4px 0;
			}
			.latest-list .l-date {
				font-size: 13px;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.latest-list .l-title {
				font-size: 19px;
				font-weight: 600;
				line-height: 1.55;
				color: #171717;
				margin: 2px 0 0 0;
			}
			.latest-list a:hover .l-title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.latest-list li {
					grid-template-columns: 120px minmax(0, 1fr);
					column-gap: 12px;
				}
				.latest-list img {
					width: 120px;
					height: 76px;
				}
				.latest-list .l-title {
					font-size: 16px;
				}
			}
			@media (max-width: 390px) {
				.latest-list li {
					grid-template-columns: 1fr;
				}
				.latest-list img {
					width: 100%;
					height: auto;
					aspect-ratio: 16 / 9;
					margin-bottom: 8px;
				}
			}

			/* ----- Popular list placeholder (server-rendered loading state) ----- */
			.popular-loading {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				padding: 14px 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="site-tagline">Yes Today｜把今天的新聞變成能用的資訊</h1>
			<div class="featured-section">
				<h2 class="section-title">今日焦點</h2>
				<p class="section-sub">今天最值得理解的一件事</p>
				<div class="carousel-outer">
					<div class="carousel" id="hero-carousel">
						{
							featuredSlides.length > 1 && (
								<button type="button" class="carousel-arrow prev" aria-label="上一則焦點文章">‹</button>
							)
						}
						{
							featuredSlides.map((post, i) => (
								<a class={`card-link slide${i === 0 ? ' is-active' : ''}`} href={`/blog/${post.id}/`} data-slide={i}>
									<img width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									<div class="slide-text">
										{post.data.category && (
											<span class="category-badge">{getCategoryName(post.data.category)}</span>
										)}
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h2 class="title">{post.data.title}</h2>
										<p class="description">{post.data.description}</p>
									</div>
								</a>
							))
						}
						{
							featuredSlides.length > 1 && (
								<button type="button" class="carousel-arrow next" aria-label="下一則焦點文章">›</button>
							)
						}
					</div>
					{
						featuredSlides.length > 1 && (
							<div class="carousel-dots">
								{featuredSlides.map((_, i) => (
									<button type="button" data-dot={i} class={i === 0 ? 'is-active' : ''} aria-label={`第 ${i + 1} 則`} />
								))}
							</div>
						)
					}
				</div>
			</div>

			<div class="two-col-section">
				<div>
					<h2 class="col-heading">最新文章</h2>
					<ul class="latest-list">
						{
							rest.slice(0, 8).map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
										<div>
											{post.data.category && (
												<p class="l-category">
													{getCategoryName(post.data.category)}
													<span class="l-date"> ｜ <FormattedDate date={post.data.pubDate} /></span>
												</p>
											)}
											<p class="l-title">{post.data.title}</p>
										</div>
									</a>
								</li>
							))
						}
					</ul>
				</div>
				<div>
					<h2 class="col-heading">熱門文章</h2>
					<ul class="popular-list" id="popular-list">
						<li class="popular-loading">讀取熱門文章中...</li>
					</ul>
				</div>
			</div>
		</main>
		<Footer />
		<script define:vars={{ popularCandidates }}>
			(function () {
				const list = document.getElementById('popular-list');
				if (!list || !popularCandidates || !popularCandidates.length) return;

				const styleTag = document.createElement('style');
				styleTag.textContent =
					'#popular-list{list-style:none;margin:20px 0 0 0;padding:0;}' +
					'#popular-list li{display:grid;grid-template-columns:40px minmax(0,1fr);column-gap:12px;align-items:start;padding:14px 0 16px;margin:0;min-height:0;height:auto;border-bottom:1px solid #e2e2e2;}' +
					'#popular-list li:first-child{padding-top:0;}' +
					'#popular-list .p-rank{font-size:28px;font-weight:400;line-height:1.2;color:#9a9a9a;}' +
					'#popular-list .p-title{font-size:17px;font-weight:500;line-height:1.6;color:#171717;margin:0;}' +
					'#popular-list .p-sub{font-size:13px;color:#9a9a9a;margin:4px 0 0 0;}' +
					'#popular-list a, #popular-list a:visited{color:#171717;text-decoration:none;}' +
					'#popular-list a:hover{color:var(--accent);}' +
					'#popular-list a:hover .p-title{color:var(--accent);}';
				document.head.appendChild(styleTag);

				const fetches = popularCandidates.map(function (p) {
					const key = 'yes-today-post-' + p.id;
					return fetch('https://countapi.mileshilliard.com/api/v1/get/' + encodeURIComponent(key))
						.then(function (r) {
							return r.ok ? r.json() : { value: 0 };
						})
						.then(function (data) {
							return { post: p, views: data.value || 0 };
						})
						.catch(function () {
							return { post: p, views: 0 };
						});
				});

				Promise.all(fetches).then(function (results) {
					results.sort(function (a, b) {
						if (b.views !== a.views) return b.views - a.views;
						return b.post.pubDate - a.post.pubDate;
					});
					const top = results.slice(0, 6);
					if (!top.length || top.every(function (r) { return r.views === 0; })) {
						list.innerHTML = '<li class="popular-loading">目前還沒有足夠的瀏覽資料</li>';
						return;
					}
					list.innerHTML = top
						.map(function (r, i) {
							const rankLabel = String(i + 1).padStart(2, '0');
							const sub = r.post.categoryName
								? r.post.categoryName + ' · ' + r.views + ' 次瀏覽'
								: r.views + ' 次瀏覽';
							return (
								'<li><span class="p-rank">' +
								rankLabel +
								'</span>' +
								'<a href="/blog/' +
								r.post.id +
								'/"><p class="p-title">' +
								r.post.title +
								'</p><p class="p-sub">' +
								sub +
								'</p></a></li>'
							);
						})
						.join('');
				});
			})();
		</script>
		<script>
			const carousel = document.getElementById('hero-carousel');
			if (carousel) {
				const slides = Array.from(carousel.querySelectorAll('.slide'));
				const dots = Array.from(document.querySelectorAll('.carousel-dots button'));
				const prevBtn = carousel.querySelector('.carousel-arrow.prev');
				const nextBtn = carousel.querySelector('.carousel-arrow.next');
				let current = 0;
				let timer;

				function show(index) {
					slides.forEach(function (s, i) {
						s.classList.toggle('is-active', i === index);
					});
					dots.forEach(function (d, i) {
						d.classList.toggle('is-active', i === index);
					});
					current = index;
				}

				function next() {
					show((current + 1) % slides.length);
				}

				function prev() {
					show((current - 1 + slides.length) % slides.length);
				}

				function start() {
					if (slides.length > 1) {
						timer = setInterval(next, 15000);
					}
				}

				function stop() {
					if (timer) clearInterval(timer);
				}

				function restart() {
					stop();
					start();
				}

				dots.forEach(function (dot, i) {
					dot.addEventListener('click', function (e) {
						e.preventDefault();
						show(i);
						restart();
					});
				});

				if (prevBtn) {
					prevBtn.addEventListener('click', function (e) {
						e.preventDefault();
						prev();
						restart();
					});
				}

				if (nextBtn) {
					nextBtn.addEventListener('click', function (e) {
						e.preventDefault();
						next();
						restart();
					});
				}

				const carouselOuter = document.querySelector('.carousel-outer');
				if (carouselOuter) {
					carouselOuter.addEventListener('mouseenter', stop);
					carouselOuter.addEventListener('mouseleave', start);
					carouselOuter.addEventListener('focusin', stop);
					carouselOuter.addEventListener('focusout', start);
					carouselOuter.addEventListener('keydown', function (e) {
						if (e.key === 'ArrowLeft') {
							e.preventDefault();
							prev();
							restart();
						} else if (e.key === 'ArrowRight') {
							e.preventDefault();
							next();
							restart();
						}
					});
				}

				start();
			}
		</script>
	</body>
</html>
