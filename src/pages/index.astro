---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, getCategoryName } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredSlides = posts.slice(0, 5);
const rest = posts.slice(1);

const popularCandidates = posts.slice(0, 12).map((post) => ({
	id: post.id,
	title: post.data.title,
	heroImage: post.data.heroImage ?? '',
	category: post.data.category ?? '',
	categoryName: post.data.category ? getCategoryName(post.data.category) : '',
}));
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				overflow-x: hidden;
			}
			.site-tagline {
				font-size: 0.95rem;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				margin: 1em 0 0 0;
			}
			.section-title {
				font-size: 0.9rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.4em;
				margin: 0 0 0.3em 0;
			}
			.section-sub {
				margin: 0.6em 0 1.3em 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.featured-section {
				margin-top: 1.5em;
			}
			.two-col-section {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 48px;
				margin-top: 56px;
			}
			@media (max-width: 720px) {
				.two-col-section {
					grid-template-columns: 1fr;
					gap: 32px;
				}
				.two-col-section {
					margin-top: 40px;
				}
			}
			.carousel-outer {
				position: relative;
				background: #A0C8FA;
				border-radius: 20px;
				padding: 28px 56px;
				box-sizing: border-box;
			}
			@media (max-width: 720px) {
				.carousel-outer {
					padding: 16px 40px;
				}
			}
			.carousel {
				display: grid;
			}
			.carousel a.slide {
				grid-area: 1 / 1;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 24px;
				align-items: stretch;
				visibility: hidden;
				opacity: 0;
				pointer-events: none;
			}
			@media (prefers-reduced-motion: no-preference) {
				.carousel a.slide {
					transition: opacity 0.25s ease;
				}
			}
			.carousel a.slide.is-active {
				visibility: visible;
				opacity: 1;
				pointer-events: auto;
			}
			.slide-text {
				background: #fff;
				border-radius: 14px;
				padding: 28px;
				display: flex;
				flex-direction: column;
				justify-content: center;
				box-sizing: border-box;
			}
			.slide img {
				width: 100%;
				height: 100%;
				min-height: 320px;
				object-fit: cover;
				border-radius: 14px;
				display: block;
			}
			.slide .title {
				margin: 0 0 0.5em 0;
				font-size: 1.7rem;
				line-height: 1.4;
				color: rgb(var(--black));
			}
			.slide .description {
				color: rgb(var(--gray-dark));
				line-height: 1.7;
				margin: 0;
			}
			.date {
				margin: 0.3em 0 0.6em 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.category-badge {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.75rem;
				font-weight: 700;
				padding: 0.2em 0.7em;
				border-radius: 4px;
				margin-bottom: 0.5em;
				width: fit-content;
			}
			.carousel-arrow {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				z-index: 5;
				width: 40px;
				height: 40px;
				border-radius: 50%;
				border: none;
				background: #fff;
				color: rgb(var(--gray-dark));
				font-size: 1.4rem;
				line-height: 1;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				box-shadow: var(--box-shadow);
			}
			.carousel-arrow:hover {
				color: var(--accent);
			}
			.carousel-arrow.prev {
				left: 12px;
			}
			.carousel-arrow.next {
				right: 12px;
			}
			.carousel-dots {
				display: flex;
				justify-content: center;
				gap: 0.5em;
				margin-top: 1.2em;
			}
			.carousel-dots button {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				border: none;
				background: rgba(255, 255, 255, 0.5);
				padding: 0;
				cursor: pointer;
			}
			.carousel-dots button.is-active {
				background: #fff;
				width: 22px;
				border-radius: 4px;
				transition: width 0.2s ease;
			}
			a.card-link {
				text-decoration: none;
				display: block;
			}
			.simple-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.simple-list li {
				display: flex;
				align-items: center;
				gap: 12px;
				padding: 14px 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.simple-list li:first-child {
				padding-top: 0;
			}
			.simple-list .rank {
				font-weight: 700;
				color: var(--accent);
				font-size: 1.2rem;
				width: 22px;
				flex-shrink: 0;
				text-align: center;
			}
			.simple-list img {
				width: 84px;
				height: 60px;
				object-fit: cover;
				border-radius: 8px;
				flex-shrink: 0;
				display: block;
			}
			.simple-list .meta {
				flex: 1;
				min-width: 0;
			}
			.simple-list .s-title {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.45;
				font-weight: 600;
				color: rgb(var(--black));
			}
			.simple-list .s-title a {
				color: inherit;
				text-decoration: none;
			}
			.simple-list .s-title a:hover {
				color: var(--accent);
			}
			.simple-list .s-sub {
				margin: 0.3em 0 0 0;
				font-size: 0.78rem;
				color: rgb(var(--gray));
			}
			.mini-badge {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.7rem;
				font-weight: 700;
				padding: 0.15em 0.6em;
				border-radius: 4px;
				margin-bottom: 0.35em;
			}
			#popular-list li {
				align-items: flex-start;
				padding: 22px 0;
				gap: 16px;
			}
			#popular-list li:first-child {
				padding-top: 0;
			}
			#popular-list .rank {
				font-size: 1.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				width: 30px;
				text-align: left;
			}
			#popular-list .s-title {
				font-size: 1.05rem;
				line-height: 1.6;
				font-weight: 600;
			}
			.simple-list .loading {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				padding: 0.5em 0;
			}
			@media (max-width: 720px) {
				.carousel a.slide {
					grid-template-columns: 1fr;
				}
				.slide img {
					min-height: 200px;
					height: 200px;
				}
				.carousel-arrow.prev {
					left: 6px;
				}
				.carousel-arrow.next {
					right: 6px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="site-tagline">Yes Today｜把今天的新聞變成能用的資訊</h1>
			<div class="featured-section">
				<h2 class="section-title">今日焦點</h2>
				<p class="section-sub">今天最值得理解的一件事</p>
				<div class="carousel-outer">
					<div class="carousel" id="hero-carousel">
						{
							featuredSlides.length > 1 && (
								<button type="button" class="carousel-arrow prev" aria-label="上一則">‹</button>
							)
						}
						{
							featuredSlides.map((post, i) => (
								<a class={`card-link slide${i === 0 ? ' is-active' : ''}`} href={`/blog/${post.id}/`} data-slide={i}>
									<img width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									<div class="slide-text">
										{post.data.category && (
											<span class="category-badge">{getCategoryName(post.data.category)}</span>
										)}
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h2 class="title">{post.data.title}</h2>
										<p class="description">{post.data.description}</p>
									</div>
								</a>
							))
						}
						{
							featuredSlides.length > 1 && (
								<button type="button" class="carousel-arrow next" aria-label="下一則">›</button>
							)
						}
					</div>
					{
						featuredSlides.length > 1 && (
							<div class="carousel-dots">
								{featuredSlides.map((_, i) => (
									<button type="button" data-dot={i} class={i === 0 ? 'is-active' : ''} aria-label={`第 ${i + 1} 則`} />
								))}
							</div>
						)
					}
				</div>
			</div>

			<div class="two-col-section">
				<div>
					<h2 class="section-title">最新文章</h2>
					<ul class="simple-list">
						{
							rest.slice(0, 6).map((post) => (
								<li>
									<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
									<div class="meta">
										<p class="s-title">
											<a href={`/blog/${post.id}/`}>{post.data.title}</a>
										</p>
										<p class="s-sub">
											{post.data.category && getCategoryName(post.data.category) + '｜'}
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</li>
							))
						}
					</ul>
				</div>
				<div>
					<h2 class="section-title">熱門文章</h2>
					<ul class="simple-list" id="popular-list">
						<li class="loading">讀取熱門文章中...</li>
					</ul>
				</div>
			</div>
		</main>
		<Footer />
		<script define:vars={{ popularCandidates }}>
			(function () {
				const list = document.getElementById('popular-list');
				if (!list || !popularCandidates || !popularCandidates.length) return;

				const fetches = popularCandidates.map(function (p) {
					const key = 'yes-today-post-' + p.id;
					return fetch('https://countapi.mileshilliard.com/api/v1/get/' + encodeURIComponent(key))
						.then(function (r) {
							return r.ok ? r.json() : { value: 0 };
						})
						.then(function (data) {
							return { post: p, views: data.value || 0 };
						})
						.catch(function () {
							return { post: p, views: 0 };
						});
				});

				Promise.all(fetches).then(function (results) {
					results.sort(function (a, b) {
						return b.views - a.views;
					});
					const top = results.slice(0, 6);
					if (!top.length || top.every(function (r) { return r.views === 0; })) {
						list.innerHTML = '<li class="loading">目前還沒有足夠的瀏覽資料</li>';
						return;
					}
					list.innerHTML = top
						.map(function (r, i) {
							const badge = r.post.categoryName
								? '<span class="mini-badge">' + r.post.categoryName + '</span>'
								: '';
							return (
								'<li><span class="rank">' +
								(i + 1) +
								'</span>' +
								'<div class="meta">' +
								badge +
								'<p class="s-title"><a href="/blog/' +
								r.post.id +
								'/">' +
								r.post.title +
								'</a></p></div></li>'
							);
						})
						.join('');
				});
			})();
		</script>
		<script>
			const carousel = document.getElementById('hero-carousel');
			if (carousel) {
				const slides = Array.from(carousel.querySelectorAll('.slide'));
				const dots = Array.from(document.querySelectorAll('.carousel-dots button'));
				const prevBtn = carousel.querySelector('.carousel-arrow.prev');
				const nextBtn = carousel.querySelector('.carousel-arrow.next');
				let current = 0;
				let timer;

				function show(index) {
					slides.forEach(function (s, i) {
						s.classList.toggle('is-active', i === index);
					});
					dots.forEach(function (d, i) {
						d.classList.toggle('is-active', i === index);
					});
					current = index;
				}

				function next() {
					show((current + 1) % slides.length);
				}

				function prev() {
					show((current - 1 + slides.length) % slides.length);
				}

				function start() {
					if (slides.length > 1) {
						timer = setInterval(next, 15000);
					}
				}

				function stop() {
					if (timer) clearInterval(timer);
				}

				function restart() {
					stop();
					start();
				}

				dots.forEach(function (dot, i) {
					dot.addEventListener('click', function (e) {
						e.preventDefault();
						show(i);
						restart();
					});
				});

				if (prevBtn) {
					prevBtn.addEventListener('click', function (e) {
						e.preventDefault();
						prev();
						restart();
					});
				}

				if (nextBtn) {
					nextBtn.addEventListener('click', function (e) {
						e.preventDefault();
						next();
						restart();
					});
				}

				start();
			}
		</script>
	</body>
</html>
