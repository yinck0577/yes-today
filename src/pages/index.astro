---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, getCategoryName } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredSlides = posts.slice(0, 5);
const rest = posts.slice(1);
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}
			.site-tagline {
				font-size: 0.95rem;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				margin: 1em 0 0 0;
			}
			.section-title {
				font-size: 0.9rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.4em;
				margin: 1.5em 0 1em 0;
			}
			.carousel {
				position: relative;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 2em;
			}
			.carousel a.slide {
				display: none;
				grid-template-columns: 1.2fr 1fr;
				gap: 2em;
				align-items: center;
				height: 360px;
			}
			.carousel a.slide.is-active {
				display: grid;
			}
			.slide img {
				width: 100%;
				height: 360px;
				object-fit: cover;
				border-radius: 12px;
				display: block;
			}
			.slide .title {
				margin: 0 0 0.4em 0;
				font-size: 1.9rem;
				line-height: 1.2;
				color: rgb(var(--black));
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.slide .description {
				color: rgb(var(--gray-dark));
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.date {
				margin: 0.3em 0 0.6em 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.category-badge {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.75rem;
				font-weight: 700;
				padding: 0.2em 0.7em;
				border-radius: 4px;
				margin-bottom: 0.5em;
			}
			.carousel-arrow {
				position: absolute;
				top: 40%;
				transform: translateY(-50%);
				z-index: 5;
				width: 36px;
				height: 36px;
				border-radius: 50%;
				border: 1px solid rgb(var(--gray-light));
				background: rgba(255, 255, 255, 0.9);
				color: rgb(var(--gray-dark));
				font-size: 1.3rem;
				line-height: 1;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				box-shadow: var(--box-shadow);
			}
			.carousel-arrow:hover {
				color: var(--accent);
				border-color: var(--accent);
			}
			.carousel-arrow.prev {
				left: -18px;
			}
			.carousel-arrow.next {
				right: -18px;
			}
			.carousel-dots {
				display: flex;
				justify-content: center;
				gap: 0.5em;
				margin-top: 1.2em;
			}
			.carousel-dots button {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				border: none;
				background: rgb(var(--gray-light));
				padding: 0;
				cursor: pointer;
			}
			.carousel-dots button.is-active {
				background: var(--accent);
				width: 22px;
				border-radius: 4px;
				transition: width 0.2s ease;
			}
			a.card-link {
				text-decoration: none;
				display: block;
			}
			.news-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
			}
			.news-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 1em;
			}
			.news-list img {
				width: 100%;
				border-radius: 10px;
				margin-bottom: 0.6em;
				display: block;
			}
			.news-list .title {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.35;
				color: rgb(var(--black));
			}
			a:hover .title,
			a:hover .date {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.carousel a.slide.is-active {
					grid-template-columns: 1fr;
					height: auto;
				}
				.slide img {
					height: 200px;
				}
				.news-list {
					grid-template-columns: 1fr;
				}
				.carousel-arrow.prev {
					left: 0;
				}
				.carousel-arrow.next {
					right: 0;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="site-tagline">Yes Today｜把今天的新聞變成能用的資訊</h1>
			<h2 class="section-title">今日焦點</h2>
			<div class="carousel" id="hero-carousel">
				{
					featuredSlides.length > 1 && (
						<button type="button" class="carousel-arrow prev" aria-label="上一則">‹</button>
					)
				}
				{
					featuredSlides.map((post, i) => (
						<a class={`card-link slide${i === 0 ? ' is-active' : ''}`} href={`/blog/${post.id}/`} data-slide={i}>
							<div class="slide-inner" style="display:contents">
								<img width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
								<div>
									{post.data.category && (
										<span class="category-badge">{getCategoryName(post.data.category)}</span>
									)}
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="title">{post.data.title}</h2>
									<p class="description">{post.data.description}</p>
								</div>
							</div>
						</a>
					))
				}
				{
					featuredSlides.length > 1 && (
						<button type="button" class="carousel-arrow next" aria-label="下一則">›</button>
					)
				}
				{
					featuredSlides.length > 1 && (
						<div class="carousel-dots">
							{featuredSlides.map((_, i) => (
								<button type="button" data-dot={i} class={i === 0 ? 'is-active' : ''} aria-label={`第 ${i + 1} 則`} />
							))}
						</div>
					)
				}
			</div>

			<h2 class="section-title">更多新聞</h2>
			<ul class="news-list">
				{
					rest.map((post) => (
						<li>
							<a class="card-link" href={`/blog/${post.id}/`}>
								<img width={360} height={200} src={post.data.heroImage} alt={post.data.title} loading="lazy" />
								{post.data.category && (
									<span class="category-badge">{getCategoryName(post.data.category)}</span>
								)}
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3 class="title">{post.data.title}</h3>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
		<script>
			const carousel = document.getElementById('hero-carousel');
			if (carousel) {
				const slides = Array.from(carousel.querySelectorAll('.slide'));
				const dots = Array.from(carousel.querySelectorAll('.carousel-dots button'));
				const prevBtn = carousel.querySelector('.carousel-arrow.prev');
				const nextBtn = carousel.querySelector('.carousel-arrow.next');
				let current = 0;
				let timer;

				function show(index) {
					slides.forEach(function (s, i) {
						s.classList.toggle('is-active', i === index);
					});
					dots.forEach(function (d, i) {
						d.classList.toggle('is-active', i === index);
					});
					current = index;
				}

				function next() {
					show((current + 1) % slides.length);
				}

				function prev() {
					show((current - 1 + slides.length) % slides.length);
				}

				function start() {
					if (slides.length > 1) {
						timer = setInterval(next, 15000);
					}
				}

				function stop() {
					if (timer) clearInterval(timer);
				}

				function restart() {
					stop();
					start();
				}

				dots.forEach(function (dot, i) {
					dot.addEventListener('click', function (e) {
						e.preventDefault();
						show(i);
						restart();
					});
				});

				if (prevBtn) {
					prevBtn.addEventListener('click', function (e) {
						e.preventDefault();
						prev();
						restart();
					});
				}

				if (nextBtn) {
					nextBtn.addEventListener('click', function (e) {
						e.preventDefault();
						next();
						restart();
					});
				}

				start();
			}
		</script>
	</body>
</html>
