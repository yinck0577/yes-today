---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, CATEGORIES, getCategoryName } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
	return CATEGORIES.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const categoryName = getCategoryName(slug as string);

const posts = (await getCollection('blog', ({ data }) => data.category === slug)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${categoryName} - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}
			.page-title {
				font-size: 1.8rem;
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.5em;
				margin: 1.5em 0 1em 0;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(33.333% - 1.4rem);
			}
			ul li img {
				width: 100%;
				border-radius: 12px;
				margin-bottom: 0.5rem;
			}
			ul li a {
				display: block;
				text-decoration: none;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.date {
				margin: 0.3em 0 0 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.empty {
				color: rgb(var(--gray));
				padding: 2em 0;
			}
			@media (max-width: 720px) {
				ul li {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">{categoryName}</h1>
			{
				posts.length === 0 && (
					<p class="empty">這個分類目前還沒有文章。</p>
				)
			}
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<img width={360} height={200} src={post.data.heroImage} alt="" />
								)}
								<h4 class="title">{post.data.title}</h4>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
