---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCategoryName, SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { currentId?: string };

const { title, description, pubDate, updatedDate, heroImage, category, currentId } = Astro.props;

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestOverall = allPosts[0];
const latestPick =
	latestOverall && latestOverall.id === currentId ? allPosts[1] : latestOverall;

function shuffle<T>(arr: T[]): T[] {
	const a = [...arr];
	for (let i = a.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[a[i], a[j]] = [a[j], a[i]];
	}
	return a;
}

const sameCategoryPool = allPosts.filter(
	(p) => p.id !== currentId && p.data.category === category && (!latestPick || p.id !== latestPick.id),
);
const randomPicks = shuffle(sameCategoryPool).slice(0, 2);

const related = [latestPick, ...randomPicks].filter(Boolean) as typeof allPosts;

const counterKey = `yes-today-post-${currentId}`;

const absoluteImageURL = heroImage ? new URL(heroImage, Astro.url) : undefined;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleLD = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	image: absoluteImageURL ? [absoluteImageURL.toString()] : undefined,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	author: [{ '@type': 'Organization', name: SITE_TITLE }],
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: { '@type': 'ImageObject', url: new URL('/yestodaylogo.png', Astro.url).toString() },
	},
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
	articleSection: category ? getCategoryName(category) : undefined,
	inLanguage: 'zh-Hant',
};
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={title} description={description} image={heroImage} type="article" />
		<script type="application/ld+json" set:html={JSON.stringify(articleLD)} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85em;
			}
			.byline {
				display: block;
			}
			.post-meta {
				display: flex;
				align-items: center;
				justify-content: center;
				flex-wrap: wrap;
				gap: 1em;
				margin: 0.5em 0 1.5em 0;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.view-count {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.share-buttons {
				display: flex;
				gap: 0.6em;
			}
			.share-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.4em 0.9em;
				border-radius: 20px;
				font-size: 0.85rem;
				text-decoration: none;
				color: #fff;
				font-weight: 600;
			}
			.share-btn.fb {
				background: #1877f2;
			}
			.share-btn.line {
				background: #06c755;
			}
			.share-btn:hover {
				opacity: 0.85;
			}
			.related {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto 3em auto;
				padding: 1em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.related h2 {
				font-size: 1.3rem;
				margin: 1em 0 1em 0;
			}
			.related-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
			}
			.related-list li a {
				display: block;
				text-decoration: none;
			}
			.related-list img {
				width: 100%;
				border-radius: 10px;
				margin-bottom: 0.5em;
				display: block;
			}
			.related-badge {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.7rem;
				font-weight: 700;
				padding: 0.15em 0.6em;
				border-radius: 4px;
				margin-bottom: 0.4em;
			}
			.related-title {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.45;
				color: rgb(var(--black));
			}
			.related-date {
				margin: 0.3em 0 0 0;
				color: rgb(var(--gray));
				font-size: 0.8rem;
			}
			.related-list a:hover .related-title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.related-list {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<span class="byline">Yes Today 編輯部｜發布於 <FormattedDate date={pubDate} /></span>
							<div class="last-updated-on">
								最後更新：<FormattedDate date={updatedDate ?? pubDate} />
							</div>
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<div class="post-meta">
						<span class="view-count" id="view-count">瀏覽數讀取中...</span>
						<div class="share-buttons">
							<a id="share-fb" class="share-btn fb" href="#" target="_blank" rel="noopener">分享到 Facebook</a>
							<a id="share-line" class="share-btn line" href="#" target="_blank" rel="noopener">分享到 LINE</a>
						</div>
					</div>
					<slot />
				</div>
			</article>
			{
				related.length > 0 && (
					<div class="related">
						<h2>延伸閱讀</h2>
						<ul class="related-list">
							{related.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<img width={360} height={200} src={post.data.heroImage} alt={post.data.title} loading="lazy" />
										)}
										{post.data.category && (
											<span class="related-badge">{getCategoryName(post.data.category)}</span>
										)}
										<h3 class="related-title">{post.data.title}</h3>
										<p class="related-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))}
						</ul>
					</div>
				)
			}
		</main>
		<Footer />
		<script define:vars={{ counterKey }}>
			const url = window.location.href;
			const fb = document.getElementById('share-fb');
			const line = document.getElementById('share-line');
			if (fb) fb.href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url);
			if (line) line.href = 'https://social-plugins.line.me/lineit/share?url=' + encodeURIComponent(url);

			const viewEl = document.getElementById('view-count');
			fetch('https://countapi.mileshilliard.com/api/v1/hit/' + encodeURIComponent(counterKey))
				.then((r) => r.json())
				.then((data) => {
					if (viewEl) viewEl.textContent = '👁 ' + data.value + ' 次瀏覽';
				})
				.catch(() => {
					if (viewEl) viewEl.textContent = '';
				});
		</script>
	</body>
</html>
