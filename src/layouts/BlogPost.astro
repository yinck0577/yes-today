---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCategoryName, SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { currentId?: string };

const { title, description, pubDate, updatedDate, heroImage, category, currentId } = Astro.props;

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestOverall = allPosts[0];
const latestPick =
	latestOverall && latestOverall.id === currentId ? allPosts[1] : latestOverall;

function shuffle<T>(arr: T[]): T[] {
	const a = [...arr];
	for (let i = a.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[a[i], a[j]] = [a[j], a[i]];
	}
	return a;
}

const sameCategoryPool = allPosts.filter(
	(p) => p.id !== currentId && p.data.category === category && (!latestPick || p.id !== latestPick.id),
);
const randomPicks = shuffle(sameCategoryPool).slice(0, 2);

const related = [latestPick, ...randomPicks].filter(Boolean) as typeof allPosts;

const counterKey = `yes-today-post-${currentId}`;

const absoluteImageURL = heroImage ? new URL(heroImage, Astro.url) : undefined;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleLD = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	image: absoluteImageURL ? [absoluteImageURL.toString()] : undefined,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	author: [{ '@type': 'Organization', name: SITE_TITLE }],
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: { '@type': 'ImageObject', url: new URL('/yestodaylogo.png', Astro.url).toString() },
	},
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
	articleSection: category ? getCategoryName(category) : undefined,
	inLanguage: 'zh-Hant',
};
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={title} description={description} image={heroImage} type="article" />
		<script type="application/ld+json" set:html={JSON.stringify(articleLD)} />
		<style>
			#reading-progress-bar {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 3px;
				background: var(--accent);
				transform: scaleX(0);
				transform-origin: left center;
				z-index: 60;
				pointer-events: none;
			}
			@media (max-width: 720px) {
				#reading-progress-bar {
					height: 2px;
				}
			}
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: clamp(2rem, 4vw, 3rem);
				font-weight: 700;
				line-height: 1.25;
				letter-spacing: -0.02em;
				word-break: normal;
				overflow-wrap: break-word;
			}
			@media (max-width: 768px) {
				.title h1 {
					font-size: 32px;
					line-height: 1.32;
					font-weight: 700;
					letter-spacing: -0.015em;
					margin-top: 16px;
					margin-bottom: 28px;
				}
			}
			@media (max-width: 390px) {
				.title h1 {
					font-size: 30px;
					line-height: 1.35;
				}
			}
			.prose h2 {
				font-size: 1.6rem;
				font-weight: 600;
				line-height: 1.4;
				margin-top: 1.6em;
			}
			.prose h3 {
				font-size: 1.3rem;
				font-weight: 600;
				line-height: 1.4;
				margin-top: 1.4em;
			}
			@media (max-width: 768px) {
				.prose h2 {
					font-size: 1.35rem;
				}
				.prose h3 {
					font-size: 1.15rem;
				}
			}
			@media (max-width: 390px) {
				.prose h2 {
					font-size: 1.25rem;
				}
				.prose h3 {
					font-size: 1.1rem;
				}
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.prose h2 {
				font-size: 1.6rem;
				font-weight: 600;
				line-height: 1.4;
				margin-top: 1.6em;
			}
			.prose h3 {
				font-size: 1.3rem;
				font-weight: 600;
				line-height: 1.4;
				margin-top: 1.4em;
			}
			@media (max-width: 768px) {
				.prose h2 {
					font-size: 1.35rem;
				}
				.prose h3 {
					font-size: 1.15rem;
				}
			}
			@media (max-width: 390px) {
				.prose h2 {
					font-size: 1.25rem;
				}
				.prose h3 {
					font-size: 1.1rem;
				}
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85em;
			}
			.byline {
				display: block;
			}
			.post-meta {
				display: flex;
				align-items: center;
				justify-content: center;
				flex-wrap: wrap;
				gap: 1em;
				margin: 0.5em 0 1.5em 0;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.view-count {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.share-buttons {
				display: flex;
				gap: 0.6em;
			}
			.share-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.4em 0.9em;
				border-radius: 20px;
				font-size: 0.85rem;
				text-decoration: none;
				color: #fff;
				font-weight: 600;
			}
			.share-btn.fb {
				background: #1877f2;
			}
			.share-btn.line {
				background: #06c755;
			}
			.share-btn:hover {
				opacity: 0.85;
			}
			.share-sidebar {
				position: fixed;
				left: 24px;
				top: 45%;
				transform: translateY(-50%);
				display: flex;
				flex-direction: column;
				gap: 0.8em;
				z-index: 30;
			}
			.share-icon {
				width: 42px;
				height: 42px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				color: #fff;
				text-decoration: none;
				box-shadow: var(--box-shadow);
			}
			.share-icon.fb {
				background: #1877f2;
			}
			.share-icon.line {
				background: #06c755;
			}
			.share-icon:hover {
				opacity: 0.85;
			}
			@media (min-width: 1150px) {
				.post-meta .share-buttons {
					display: none;
				}
			}
			@media (max-width: 1149px) {
				.share-sidebar {
					display: none;
				}
			}
			.related {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto 3em auto;
				padding: 1em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.related h2 {
				font-size: 1.3rem;
				margin: 1em 0 1em 0;
			}
			.related-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
			}
			.related-list li a {
				display: block;
				text-decoration: none;
			}
			.related-list img {
				width: 100%;
				border-radius: 10px;
				margin-bottom: 0.5em;
				display: block;
			}
			.related-badge {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.7rem;
				font-weight: 700;
				padding: 0.15em 0.6em;
				border-radius: 4px;
				margin-bottom: 0.4em;
			}
			.related-title {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.45;
				color: rgb(var(--black));
			}
			.related-date {
				margin: 0.3em 0 0 0;
				color: rgb(var(--gray));
				font-size: 0.8rem;
			}
			.related-list a:hover .related-title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.related-list {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<div id="reading-progress-bar"></div>
		<Header />
		<div class="share-sidebar" aria-label="分享這篇文章">
			<a id="share-fb-side" class="share-icon fb" href="#" target="_blank" rel="noopener" aria-label="分享到 Facebook">
				<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"
					><path
						fill="currentColor"
						d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z"
					></path></svg
				>
			</a>
			<a id="share-line-side" class="share-icon line" href="#" target="_blank" rel="noopener" aria-label="分享到 LINE">
				<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"
					><path
						fill="currentColor"
						d="M12 2C6.48 2 2 5.69 2 10.24c0 4.08 3.54 7.5 8.32 8.15.32.07.76.21.87.49.1.25.06.65.03.9l-.14.85c-.04.25-.19.98.86.53s5.65-3.33 7.71-5.7C21.09 13.5 22 11.96 22 10.24 22 5.69 17.52 2 12 2zm-3.5 11h-1.8a.4.4 0 0 1-.4-.4V8.4a.4.4 0 0 1 .4-.4h.8a.4.4 0 0 1 .4.4v3.4h1.6a.4.4 0 0 1 .4.4v.8a.4.4 0 0 1-.4.4zm2.6-4.6a.4.4 0 0 1-.4.4h-.8a.4.4 0 0 1-.4-.4V8.4a.4.4 0 0 1 .4-.4h.8a.4.4 0 0 1 .4.4zm5.5 4.2a.4.4 0 0 1-.4.4h-.8a.4.4 0 0 1-.32-.16l-1.68-2.27v2.03a.4.4 0 0 1-.4.4h-.8a.4.4 0 0 1-.4-.4V8.4a.4.4 0 0 1 .4-.4h.8c.13 0 .25.06.32.16l1.68 2.27V8.4a.4.4 0 0 1 .4-.4h.8a.4.4 0 0 1 .4.4z"
					></path></svg
				>
			</a>
		</div>
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<span class="byline">Yes Today 編輯部｜發布於 <FormattedDate date={pubDate} /></span>
							<div class="last-updated-on">
								最後更新：<FormattedDate date={updatedDate ?? pubDate} />
							</div>
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<div class="post-meta">
						<span class="view-count" id="view-count">瀏覽數讀取中...</span>
						<div class="share-buttons">
							<a id="share-fb" class="share-btn fb" href="#" target="_blank" rel="noopener">分享到 Facebook</a>
							<a id="share-line" class="share-btn line" href="#" target="_blank" rel="noopener">分享到 LINE</a>
						</div>
					</div>
					<slot />
				</div>
			</article>
			{
				related.length > 0 && (
					<div class="related">
						<h2>延伸閱讀</h2>
						<ul class="related-list">
							{related.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<img width={360} height={200} src={post.data.heroImage} alt={post.data.title} loading="lazy" />
										)}
										{post.data.category && (
											<span class="related-badge">{getCategoryName(post.data.category)}</span>
										)}
										<h3 class="related-title">{post.data.title}</h3>
										<p class="related-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))}
						</ul>
					</div>
				)
			}
		</main>
		<Footer />
		<script define:vars={{ counterKey }}>
			const url = window.location.href;
			const fbShareUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url);
			const lineShareUrl = 'https://social-plugins.line.me/lineit/share?url=' + encodeURIComponent(url);
			const fb = document.getElementById('share-fb');
			const line = document.getElementById('share-line');
			const fbSide = document.getElementById('share-fb-side');
			const lineSide = document.getElementById('share-line-side');
			if (fb) fb.href = fbShareUrl;
			if (line) line.href = lineShareUrl;
			if (fbSide) fbSide.href = fbShareUrl;
			if (lineSide) lineSide.href = lineShareUrl;

			const viewEl = document.getElementById('view-count');
			fetch('https://countapi.mileshilliard.com/api/v1/hit/' + encodeURIComponent(counterKey))
				.then((r) => r.json())
				.then((data) => {
					if (viewEl) viewEl.textContent = '👁 ' + data.value + ' 次瀏覽';
				})
				.catch(() => {
					if (viewEl) viewEl.textContent = '';
				});
		</script>
		<script>
			(function () {
				const bar = document.getElementById('reading-progress-bar');
				const article = document.querySelector('article');
				if (!bar || !article) return;
				let ticking = false;
				function update() {
					const rect = article.getBoundingClientRect();
					const total = article.offsetHeight - window.innerHeight;
					let progress = 1;
					if (total > 0) {
						const scrolled = -rect.top;
						progress = Math.min(1, Math.max(0, scrolled / total));
					}
					bar.style.transform = 'scaleX(' + progress + ')';
					ticking = false;
				}
				function onScroll() {
					if (!ticking) {
						window.requestAnimationFrame(update);
						ticking = true;
					}
				}
				window.addEventListener('scroll', onScroll, { passive: true });
				window.addEventListener('resize', onScroll, { passive: true });
				update();
			})();
		</script>
		<script>
			(function () {
				const prose = document.querySelector('.prose');
				if (!prose) return;
				const links = prose.querySelectorAll('a[href^="http"]');
				links.forEach(function (link) {
					if (link.hostname && link.hostname !== window.location.hostname) {
						link.setAttribute('target', '_blank');
						link.setAttribute('rel', 'noopener noreferrer');
					}
				});
			})();
		</script>
	</body>
</html>
