---
import { SITE_TITLE, CATEGORIES } from '../consts';
---

<header>
	<nav>
		<h2><a href="/" class="brand"><img src="/yestodaylogo.png" alt="Yes Today 首頁" width="32" height="32" />{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<a href="/blog">News</a>
			<a href="/about">About</a>
		</div>
	</nav>
	<nav class="category-nav">
		{
			CATEGORIES.map((c) => (
				<a href={`/category/${c.slug}/`}>{c.name}</a>
			))
		}
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 40;
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.5em;
		color: var(--black);
		font-weight: 700;
	}
	.brand img {
		display: block;
		border-radius: 8px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1em;
		margin-left: auto;
	}
	.internal-links a {
		font-size: 0.8rem;
		color: rgb(var(--gray));
		text-decoration: none;
		padding: 0.3em 0;
	}
	.internal-links a:hover {
		color: var(--accent);
	}
	.category-nav {
		display: flex;
		gap: 0.25em;
		overflow-x: auto;
		border-top: 1px solid rgb(var(--gray-light));
		padding: 0.4em 0;
	}
	.category-nav a {
		flex: none;
		padding: 0.3em 0.7em;
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		white-space: nowrap;
		border-radius: 20px;
	}
	.category-nav a:hover {
		background: rgb(var(--gray-light));
		color: var(--accent);
	}
</style>
